{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://actproof.org/schemas/source_atoms.v1.schema.json",
  "title": "ActProof source atoms v1",
  "description": "Smallest reviewable official-source units used for field-level regulatory source binding.",
  "type": "object",
  "required": [
    "schema",
    "profile_id",
    "source_atoms"
  ],
  "properties": {
    "schema": {
      "const": "actproof.source_atoms.v1"
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "source_atoms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_atom_id",
          "source_binding_id",
          "source_id",
          "celex",
          "eli",
          "instrument",
          "authority",
          "atom_type",
          "locator",
          "source_role",
          "normative_weight",
          "language",
          "source_document_sha256",
          "atom_identity_sha256",
          "atom_hash_basis",
          "derivation_note",
          "review_status"
        ],
        "properties": {
          "source_atom_id": {
            "type": "string",
            "pattern": "^src\\.eu\\.dora\\."
          },
          "source_binding_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "pattern": "^CELEX:"
          },
          "celex": {
            "type": "string",
            "minLength": 1
          },
          "eli": {
            "type": "string",
            "minLength": 1
          },
          "instrument": {
            "type": "string",
            "minLength": 1
          },
          "authority": {
            "type": "string",
            "minLength": 1
          },
          "atom_type": {
            "enum": [
              "article",
              "paragraph",
              "point",
              "annex",
              "annex_section",
              "template_section",
              "template_field",
              "glossary_entry",
              "classification_rule",
              "threshold_rule",
              "cross_reference"
            ]
          },
          "locator": {
            "type": "object",
            "minProperties": 1
          },
          "source_role": {
            "enum": [
              "base_obligation",
              "reporting_sequence",
              "reporting_channel",
              "content_requirement",
              "time_limit",
              "template_section",
              "template_field",
              "data_glossary",
              "classification_criteria",
              "major_incident_threshold",
              "operational_context",
              "boundary_or_non_claim"
            ]
          },
          "normative_weight": {
            "enum": [
              "primary",
              "supporting",
              "contextual"
            ]
          },
          "language": {
            "type": "string",
            "minLength": 2
          },
          "text_excerpt": {
            "type": "string"
          },
          "source_document_sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "atom_identity_sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "atom_hash_basis": {
            "type": "string",
            "minLength": 1
          },
          "derivation_note": {
            "type": "string",
            "minLength": 1
          },
          "review_status": {
            "enum": [
              "draft",
              "maintainer_reviewed",
              "independent_reviewed",
              "external_legal_reviewed",
              "deprecated",
              "superseded"
            ]
          },
          "official_text_sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "binding_status": {
            "type": "string",
            "enum": [
              "verified",
              "provisional"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}